# Production environment (Cloud Run). Set these as Cloud Run service env vars
# / secrets — do NOT commit real values. See DEPLOY.md for how to obtain each.

# --- Postgres (Neon; serverless, scales to zero) ---
# Use a CLEAN URL with no ssl query args — DB_REQUIRE_SSL handles TLS for both
# the async (asyncpg) and Alembic (psycopg2) drivers.
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/DBNAME
DB_REQUIRE_SSL=true

# --- Redis (Upstash; serverless, TLS) ---
REDIS_URL=rediss://default:PASSWORD@RENAME.upstash.io:6379

# --- Object storage (GCS) ---
MATRIX_STORAGE_BACKEND=gcs
MATRIX_STORAGE_BUCKET=your-bucket-name
# GCS auth comes from the Cloud Run service account, not a key file.

# --- CORS: the deployed frontend origin(s), comma-separated ---
CORS_ORIGINS=https://your-frontend.vercel.app

# --- AlphaMissense (optional) ---
# The ~1.2GB SQLite isn't shipped in the image. To enable AlphaMissense in
# prod, bake it into the worker image or mount it, and point this at it;
# otherwise the app runs fine without it.
# ALPHAMISSENSE_DB_PATH=/data/alphamissense.sqlite
