# Copy to .env and adjust for local development.
# .env is gitignored; .env.example is committed.

DATABASE_URL=postgresql+asyncpg://protein:protein_dev_password@localhost:5432/protein_variant_db
REDIS_URL=redis://localhost:6379

# Matrix storage: "local" (filesystem) or "gcs"
MATRIX_STORAGE_BACKEND=local
MATRIX_STORAGE_PATH=./data/matrices
# MATRIX_STORAGE_BUCKET=your-bucket-name    # only when backend=gcs
